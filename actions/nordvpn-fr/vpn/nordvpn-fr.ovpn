# NordVPN French Exit Node — OpenVPN profile
# Ported to pau-vega/nordvpn-actions from NordVPN reference configuration
# Note: `remote` line is overridden by connect.sh via `--remote <host> 1194` CLI flag (per D-13)
# The CLI flag takes precedence over the config file's remote directive.

client
dev tun
proto udp
remote fr.nordvpn.com 1194
resolv-retry infinite
nobind
persist-key
persist-tun
cipher AES-256-CBC
auth SHA512
data-ciphers AES-256-GCM:AES-256-CBC
ping 15
ping-restart 0
server-poll-timeout 10
reneg-sec 0
pull-filter ignore "auth-token"
pull-filter ignore "signal"
script-security 2
up /etc/openvpn/update-systemd-resolved
down /etc/openvpn/update-systemd-resolved
up-restart
down-pre

